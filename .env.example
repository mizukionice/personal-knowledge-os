# ============================================================
# Personal Knowledge OS — 環境変数テンプレート
# 実際の値は .env（gitignore済み）に置く。コードにハードコードしない。
# ============================================================

# --- apps/web (Vite) ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_API_BASE_URL=http://localhost:8787

# --- workers/api (Cloudflare Workers) ---
# 本番では wrangler secret で設定。R2の読み書きはwranglerのbindingを使用し、
# 署名付きアップロードURLの発行にはS3互換APIのキーを使用する
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_JWT_SECRET=your-jwt-secret
GITHUB_DISPATCH_TOKEN=ghp_your-token-with-repo-scope
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
CF_ACCOUNT_ID=your-cloudflare-account-id
R2_BUCKET=personal-knowledge-os

# --- migrations (supabase db push --db-url 用) ---
SUPABASE_DB_PASSWORD=your-db-password

# --- workers/batch (GitHub Actions) ---
# 本番では GitHub Secrets で設定
ANTHROPIC_API_KEY=sk-ant-your-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
CF_ACCOUNT_ID=your-cloudflare-account-id
CF_AI_TOKEN=your-workers-ai-token
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET=personal-knowledge-os
